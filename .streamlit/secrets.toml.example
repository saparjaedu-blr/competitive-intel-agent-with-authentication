# .streamlit/secrets.toml
# ⚠️  This file is gitignored — never commit it.
# Copy this template, fill in your values, save as .streamlit/secrets.toml

# ── Streamlit Native Google OAuth ─────────────────────────────────────────────
# 1. Go to console.cloud.google.com
# 2. Create OAuth 2.0 Client ID → Web Application
# 3. Add Authorised Redirect URIs:
#      http://localhost:8501/oauth2callback          (local dev)
#      https://your-app.streamlit.app/oauth2callback (deployed)

[auth]
redirect_uri         = "https://comp-intel-analysis-agent.streamlit.app/oauth2callback"
cookie_secret        = "change_this_to_a_long_random_hex_string"
client_id            = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret        = "YOUR_GOOGLE_CLIENT_SECRET"
server_metadata_url  = "https://accounts.google.com/.well-known/openid-configuration"
